
MDScreenManager:
    id: display_screen


    MDScreen:
        name: "home_screen"
        
        MDBoxLayout:
            orientation: "vertical"
            md_bg_color: app.color_scheme['bg']

            MDTopAppBar:
                title: app.app_name

            MDLabel:
                text: "HSC"
                size_hint_y: .05
                halign: "center"
            
            # scroll video of cards
            ScrollView:
                MDGridLayout:
                    id: subjects
                    cols: 2
                    spacing: "12dp"
                    padding: "12dp"
                    adaptive_height: True
            

    MDScreen:
        name: "chapters"
        
        MDBoxLayout:
            orientation: "vertical"
            md_bg_color: app.color_scheme['bg']

            MDTopAppBar:
                id: subject_name
                title: 'subject_name'
                left_action_items: 
                    [["arrow-left", lambda x: app.change_screen('home_screen')]]

            MDScrollView:
                MDList:
                    id: container
            

    MDScreen:
        name: "sections"

        MDBoxLayout:
            orientation: "vertical"
            md_bg_color: app.color_scheme['bg']

            MDTopAppBar:
                id: chapter_name
                title: 'chapter_name'
                left_action_items: [["arrow-left", lambda x: app.change_screen('chapters')]]

            MDScrollView:
                MDList:
                    id: sub_chapter

